    {
      "name": "3. Messages",
      "item": [
        {
          "name": "Fetch Messages (Cursor-based)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/rooms/ROOM_ID/messages?limit=20&cursor=ISO_DATE_STRING_HERE",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "rooms",
                "ROOM_ID",
                "messages"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "ISO_DATE_STRING_HERE",
                  "description": "Pass createdAt value of the oldest retrieved message here for next page"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Mark Room Messages Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
