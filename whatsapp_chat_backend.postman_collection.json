            "method": "POST",
            "url": {
              "raw": "{{base_url}}/rooms/ROOM_ID/messages/read",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "rooms",
                "ROOM_ID",
                "messages",
                "read"
              ]
            }
          },
          "response": []
